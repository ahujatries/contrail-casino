{
  "name": "airport-pong",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter web dev",
    "worker": "pnpm --filter worker dev",
    "worker:prod": "pnpm --filter worker start",
    "db:push": "pnpm --filter @airport-pong/db push",
    "db:migrate": "pnpm --filter @airport-pong/db migrate",
    "db:studio": "pnpm --filter @airport-pong/db studio",
    "db:generate": "pnpm --filter @airport-pong/db generate"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20"
  }
}
